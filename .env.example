# Supabase server-side config
# Usa la URL de tu proyecto y una service role key real en tu entorno local.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_tu_service_role_key

# Tablas de correlaciones
SUPABASE_TABLE_AUDITORIAS_ETB_RETENCION=Las_tablas_especificas
SUPABASE_TABLE_CELULA_ANTIFRAUDE=Las_tablas_especificas
SUPABASE_TABLE_EFECTIVIDAD=Las_tablas_especificas
SUPABASE_TABLE_VOZ_CLIENTE=Las_tablas_especificas
SUPABASE_TABLE_NPS_FCR=Las_tablas_especificas

# Tablas de reportes de calidad
SUPABASE_TABLE_REPORTES_CALIDAD_SOUL=Las_tablas_especificas
SUPABASE_TABLE_REPORTES_CALIDAD_ANTIFRAUDE=Las_tablas_especificas
SUPABASE_TABLE_REPORTES_CALIDAD_SPEECH=Las_tablas_especificas
SUPABASE_TABLE_REPORTES_CALIDAD_REINCIDENTES=Las_tablas_especificas
